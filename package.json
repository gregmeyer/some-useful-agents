{
  "name": "some-useful-agents",
  "version": "0.0.0",
  "private": true,
  "description": "A local-first agent playground. Author, schedule, and report on agents running on your machine.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build && node packages/dashboard/scripts/copy-assets.mjs && node packages/dashboard/scripts/gen-build-info.mjs && chmod +x packages/cli/dist/index.js",
    "clean": "tsc --build --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "validate-agents": "node packages/core/dist/validate-agents.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gregmeyer/some-useful-agents.git"
  },
  "keywords": [
    "agents",
    "mcp",
    "temporal",
    "cli",
    "orchestration"
  ],
  "author": "Greg Meyer",
  "license": "MIT",
  "engines": {
    "node": ">=22.5.0"
  },
  "overrides": {
    "protobufjs": ">=7.5.5"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.1",
    "vitest": "4.1.10"
  }
}
